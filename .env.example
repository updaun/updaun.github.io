# 웹 이미지 매칭을 위한 API 키 설정
# 이 파일을 .env로 복사하고 실제 API 키를 입력하세요

# Unsplash API (고품질 사진, 시간당 50회 무료)
# 발급: https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# Pexels API (무료 스톡 사진, 시간당 200회 무료)
# 발급: https://www.pexels.com/api/
PEXELS_API_KEY=your_pexels_api_key_here

# Pixabay API (다양한 이미지, 시간당 5,000회 무료)
# 발급: https://pixabay.com/api/docs/
PIXABAY_API_KEY=your_pixabay_api_key_here

# 이미지 품질 설정 (선택사항)
IMAGE_QUALITY=85
IMAGE_WIDTH=1200
IMAGE_HEIGHT=630

# 캐시 만료 시간 (일 단위, 선택사항)
CACHE_EXPIRES_DAYS=7

# ------------------------------
# Cloudflare R2 업로드 설정
# ------------------------------
# 발급 경로:
# - R2 API Token: Cloudflare Dashboard > R2 > Manage R2 API Tokens
# - Account ID: Cloudflare Dashboard 우측 하단
CF_R2_ACCOUNT_ID=your_cloudflare_account_id_here
CF_R2_ACCESS_KEY_ID=your_r2_access_key_id_here
CF_R2_SECRET_ACCESS_KEY=your_r2_secret_access_key_here
CF_R2_BUCKET=your_r2_bucket_name_here
CF_R2_CDN_BASE=https://pub-xxxx.r2.dev